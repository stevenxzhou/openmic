    "clsx": "^2.1.1",
    "lucide-react": "^0.477.0",
    "mariadb": "3.4.2",
    "next": "14.2.16",
    "react": "^18",
    "react-dom": "^18",
    "react-draggable": "^4.4.6",
    "react-social-icons": "^6.25.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
